# Virtual mailbox maps lookup

hosts = postgres
user = mailservice
password = ${DB_PASSWORD}
dbname = mailservice

query = SELECT CONCAT(u.local_part, '@', d.name, '/') FROM users u JOIN domains d ON u.domain_id = d.id WHERE u.local_part = '%u' AND d.name = '%d' AND u.frozen = false AND (u.delete_after IS NULL OR u.delete_after > CURRENT_DATE)
