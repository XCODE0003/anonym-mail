# =============================================================================
# owl.li — Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
APP_ENV=production
APP_DEBUG=false
APP_URL=https://owl.li
PRIMARY_DOMAIN=owl.li
BRAND_NAME="owlmail"

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mailservice
DB_USER=mailservice
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# MAIL STACK
# -----------------------------------------------------------------------------
MAIL_HOSTNAME=mail.anonym-mail-service.test
POSTFIX_RELAY_HOST=
SMTP_PORT_25=25
SMTP_PORT_465=465
SMTP_PORT_587=587
IMAP_PORT=993
POP3_PORT=995

# Default mailbox quota in bytes (1GB = 1073741824)
DEFAULT_QUOTA_BYTES=1073741824

# Max attachment size in bytes (25MB = 26214400)
MAX_ATTACHMENT_BYTES=26214400

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# CSRF token length (hex chars)
CSRF_TOKEN_LENGTH=32

# Session lifetime in seconds (24 hours = 86400)
SESSION_LIFETIME=86400

# CAPTCHA settings
CAPTCHA_ENABLED=true
CAPTCHA_LENGTH=6
CAPTCHA_TTL_SECONDS=600

# PoW difficulty (bits of leading zeros, 22 ≈ 1-3 min CPU)
POW_DIFFICULTY_BITS=22
POW_CHALLENGE_TTL_SECONDS=1800

# Rate limits
RATE_LIMIT_UNBLOCK_PER_HOUR=5
RATE_LIMIT_REGISTER_PER_HOUR=10

# Account deletion delay in days
ACCOUNT_DELETION_DELAY_DAYS=30

# -----------------------------------------------------------------------------
# ADMIN PANEL
# -----------------------------------------------------------------------------
ADMIN_HOST=admin.anonym-mail-service.test
ADMIN_IP_ALLOWLIST=127.0.0.1,::1

# mTLS client certificate (path relative to config/)
ADMIN_CLIENT_CA=/certs/admin-ca.crt

# -----------------------------------------------------------------------------
# TLS CERTIFICATES (acme.sh)
# -----------------------------------------------------------------------------
ACME_EMAIL=admin@anonym-mail-service.test
ACME_DNS_PROVIDER=dns_cf
# For Cloudflare:
CF_Token=
CF_Account_ID=
CF_Zone_ID=

# -----------------------------------------------------------------------------
# TOR (optional)
# -----------------------------------------------------------------------------
TOR_ENABLED=true
TOR_CONTROL_PASSWORD=CHANGE_ME_TOR_PASSWORD
# These will be auto-generated on first run
TOR_WWW_ONION=
TOR_MAIL_ONION=

# -----------------------------------------------------------------------------
# XMPP (optional, disabled by default)
# -----------------------------------------------------------------------------
XMPP_ENABLED=false
XMPP_HOST=xmpp.anonym-mail-service.test

# -----------------------------------------------------------------------------
# DKIM
# -----------------------------------------------------------------------------
# Selector prefix (will append YYYYMM)
DKIM_SELECTOR_PREFIX=mail

# -----------------------------------------------------------------------------
# WARRANT CANARY
# -----------------------------------------------------------------------------
# GPG key ID for signing canary (generated in make init if empty)
CANARY_GPG_KEY_ID=

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=anonym-mail
DOCKER_NETWORK=anonym-mail-net

# Container resource limits
PHP_MEMORY_LIMIT=256M
PHP_MAX_UPLOAD=30M
PHP_MAX_POST=30M
