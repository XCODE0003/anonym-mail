{% extends 'layout.html.twig' %}

{% block body_class %}page-delete{% endblock %}

{% block content %}
<div class="page-form">
    <h1>Delete Account</h1>
    
    <div class="message message-warning">
        <p><strong>Warning:</strong> This action is irreversible. Your account and all emails 
        will be permanently deleted after {{ deletion_days }} days.</p>
    </div>
    
    {% if errors is defined and errors %}
    <div class="message message-error">
        <ul>
        {% for error in errors %}
            <li>{{ error }}</li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}
    
    <form method="POST" action="/delete.php">
        <input type="hidden" name="csrf" value="{{ csrf_token }}">
        <input type="hidden" name="csrf_valid" value="{{ csrf_token }}">
        
        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required>
        </div>
        
        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required>
        </div>
        
        <div class="form-group">
            <label for="captcha_solution">CAPTCHA</label>
            <div class="captcha-container">
                <img src="/captcha.php?k={{ captcha_key }}" alt="CAPTCHA image" width="200" height="60">
                <input type="text" id="captcha_solution" name="captcha_solution" 
                       autocomplete="off" required>
            </div>
            <input type="hidden" name="captcha_key" value="{{ captcha_key }}">
        </div>
        
        <div class="form-group">
            <label>
                <input type="checkbox" name="delete_confirm" required>
                I understand that my account and all data will be permanently deleted 
                after {{ deletion_days }} days
            </label>
        </div>
        
        <button type="submit" class="btn btn-danger" style="width: 100%;">Delete Account</button>
    </form>
</div>
{% endblock %}
