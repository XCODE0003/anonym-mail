{% extends 'layout.html.twig' %}

{% block body_class %}page-unblock{% endblock %}

{% block content %}
<div class="page-form" style="max-width: 600px;">
    <h1>Unblock SMTP</h1>
    
    <p>New accounts have SMTP sending blocked by default to prevent spam. 
    To unblock your account, you must complete a proof-of-work challenge.</p>
    
    <h2>How It Works</h2>
    
    <ol>
        <li>Enter your email and password below</li>
        <li>Download and run the solver script on your computer</li>
        <li>Enter the solution code to unblock SMTP</li>
    </ol>
    
    <div class="message message-warning">
        <p><strong>Note:</strong> The proof-of-work challenge requires approximately 
        1-3 minutes of CPU time. This is a one-time verification.</p>
    </div>
    
    {% if errors is defined and errors %}
    <div class="message message-error">
        <ul>
        {% for error in errors %}
            <li>{{ error }}</li>
        {% endfor %}
        </ul>
    </div>
    {% endif %}
    
    {% if challenge is defined and challenge %}
    {# Show challenge and solution input #}
    <h2>Step 2: Solve the Challenge</h2>
    
    <p>Download the solver script and run it with your challenge:</p>
    
    <pre><code>./unblock-solver.sh "{{ challenge.seed }}" "{{ challenge.salt }}" {{ challenge.difficulty }}</code></pre>
    
    <p><a href="/scripts/unblock-solver.sh" download class="btn btn-secondary">Download Solver Script</a></p>
    
    <form method="GET" action="/unblock" style="margin-top: 2rem;">
        <input type="hidden" name="email" value="{{ email }}">
        
        <div class="form-group">
            <label for="unblock_code">Solution Code</label>
            <input type="text" id="unblock_code" name="unblock_code" 
                   placeholder="Paste the code from solver output" required>
        </div>
        
        <button type="submit" class="btn btn-primary" style="width: 100%;">Verify & Unblock</button>
    </form>
    
    {% else %}
    {# Initial form #}
    <form method="POST" action="/unblock">
        <input type="hidden" name="csrf" value="{{ csrf_token }}">
        <input type="hidden" name="csrf_valid" value="{{ csrf_token }}">
        <input type="text" name="password_confirm" value="" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;height:0;width:0;opacity:0" class="honeypot">

        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required>
        </div>
        
        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required>
        </div>
        
        <button type="submit" class="btn btn-primary" style="width: 100%;">Generate Challenge</button>
    </form>
    {% endif %}
</div>
{% endblock %}
