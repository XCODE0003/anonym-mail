<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="referrer" content="no-referrer">
    <title>{% block title %}{{ page_title|default('') }}{% endblock %} — {{ brand_name }}</title>
    <link rel="stylesheet" href="/assets/css/webmail.css">
    <link rel="stylesheet" href="/assets/css/webmail-js.css">
</head>
<body class="{% block body_class %}{% endblock %}">
    {% if user %}
    <div class="webmail-layout">
        <aside class="webmail-sidebar" aria-label="Mail navigation">
            <div class="sidebar-brand">
                <a href="/webmail/inbox" class="logo">
                    {% include 'partials/owl-logo-icon.html.twig' %}
                    <span class="logo-text">{{ brand_name }}</span>
                </a>
            </div>

            <a href="/webmail/compose" class="btn btn-primary compose-btn">
                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                <span class="compose-label">Compose</span>
            </a>

            <nav class="folder-list" aria-label="Folders">
                {% for folder in folders|default([]) %}
                <a href="/webmail/folder/{{ folder|url_encode }}"
                   class="folder-item {% if current_folder|default('') == folder %}active{% endif %}">
                    {% include 'webmail/_folder_icon.html.twig' with { folder: folder } only %}
                    <span class="folder-label">{{ folder }}</span>
                </a>
                {% endfor %}
            </nav>

            <div class="sidebar-footer">
                <a href="/webmail/search" class="sidebar-link">
                    <svg class="folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <span>Search</span>
                </a>
                <a href="/webmail/settings" class="sidebar-link">
                    <svg class="folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                    <span>Settings</span>
                </a>
                <div class="sidebar-user" title="{{ user.email }}">
                    <svg class="folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <span class="sidebar-user-email">{{ user.email }}</span>
                </div>
                <a href="/webmail/logout" class="sidebar-link sidebar-link-logout">
                    <svg class="folder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
                    <span>Sign out</span>
                </a>
            </div>
        </aside>

        <div class="webmail-content">
            <main class="webmail-main server-rendered">
                {% block content %}{% endblock %}
            </main>
        </div>
    </div>

    <template id="webmail-owl-logo-tmpl">{% include 'partials/owl-logo-icon.html.twig' %}</template>

    <script src="/assets/js/imap-client.js"></script>
    <script src="/assets/js/webmail-app.js"></script>
    <script>
    (function() {
        var wsProtocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
        var wsUrl = wsProtocol + '//' + location.host + '/ws/';

        window.webmailConfig = {
            wsUrl: wsUrl,
            email: '{{ user.email|e('js') }}',
            brandName: '{{ brand_name|e('js') }}'
        };

        document.body.classList.add('js-available');
    })();
    </script>
    {% else %}
    <main class="login-page">
        {% block login_content %}{% endblock %}
    </main>
    {% endif %}
</body>
</html>
