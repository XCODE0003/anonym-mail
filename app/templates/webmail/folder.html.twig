{% extends 'webmail/layout.html.twig' %}

{% block content %}
<div class="folder-view">
    <header class="folder-header">
        <h1>{{ current_folder }}</h1>
        <span class="message-count">{{ total_messages }}</span>
    </header>

    {% if messages|length > 0 %}
    <div class="message-list">
        {% for msg in messages %}
        <a href="/webmail/message/{{ current_folder|url_encode }}/{{ msg.uid }}" 
           class="message-row {% if not msg.seen %}unread{% endif %}">
            <div class="msg-from">{{ msg.from|e }}</div>
            <div class="msg-subject">{{ msg.subject|default('(No Subject)')|e }}</div>
            <div class="msg-date">{{ msg.date|date('M j') }}</div>
        </a>
        {% endfor %}
    </div>

    {% if total_pages > 1 %}
    <nav class="pagination">
        {% if page > 1 %}
        <a href="/webmail/folder/{{ current_folder|url_encode }}?page={{ page - 1 }}" class="btn btn-secondary btn-sm">Prev</a>
        {% endif %}
        <span class="page-info">{{ page }} / {{ total_pages }}</span>
        {% if page < total_pages %}
        <a href="/webmail/folder/{{ current_folder|url_encode }}?page={{ page + 1 }}" class="btn btn-secondary btn-sm">Next</a>
        {% endif %}
    </nav>
    {% endif %}

    {% else %}
    <div class="empty-folder">
        <p>No messages</p>
    </div>
    {% endif %}
</div>
{% endblock %}
