{
    "name": "anonym-mail/app",
    "description": "Anonymous email service - PHP application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "twig/twig": "^3.10",
        "predis/predis": "^2.2",
        "ezyang/htmlpurifier": "^4.17",
        "robthree/twofactorauth": "^3.0",
        "symfony/mailer": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2",
        "phpstan/phpstan": "^1.11",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "../tests/phpunit/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse src --level 8",
        "cs-check": "phpcs --standard=PSR12 src",
        "cs-fix": "phpcbf --standard=PSR12 src"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
